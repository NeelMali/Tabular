{
  "name": "doc-table-extractor",
  "version": "1.0.0",
  "description": "Document to structured table extractor powered by Claude AI",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,magenta \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "nodemon server/index.js",
    "dev:client": "vite client --port 5173",
    "build": "vite build client --outDir ../dist",
    "start": "cross-env NODE_ENV=production node server/index.js",
    "preview": "npm run build && npm start"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "mammoth": "^1.8.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "papaparse": "^5.4.1",
    "pdf-parse": "^1.1.1",
    "xlsx": "^0.18.5",
    "@anthropic-ai/sdk": "^0.52.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "nodemon": "^3.1.9",
    "vite": "^6.3.5"
  }
}
